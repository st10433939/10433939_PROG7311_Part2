@model List<_10433939_PROG7311_Part2.Models.Contract>

﻿@{
	ViewBag.Title = "Contracts";
	Layout = "~/Views/Shared/_Layout.cshtml";
}
<body class="text-bg-secondary">
	<nav class="mb-4">
		<ol class="breadcrumb">
			<li class="breadcrumb-item"><a href="/">Home</a></li>
			<li class="breadcrumb-item active">Contracts</li>
		</ol>
	</nav>
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h2>Lecturer Contracts</h2>
		<a href="/Contracts/Add" class="btn btn-primary"> + Add New Contract </a>
	</div>
</body>
<!--Contract Table-->
<div class="card">
	<div class="card-body">
		@if (Model.Count == 0)
		{
			<div class="text-center py5">
				<p class="text-muted">No Contract submitted yet.</p>
				<a href="/Contracts/Add" class="btn btn-primary">Add your first Contract</a>
			</div>
		}
		else
		{
			<table class="table">
				<thead>
					<tr>
						<th>Start Date</th>
						<th>End Date</th>
						<th>Service Level</th>
						<th>Status</th>
						<th>Actions</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var contract in Model)
					{
						<tr>
							<td>@contract.startDate.ToString("MM-dd-yyyy")</td>
							<td>@contract.endDate.ToString("MM-dd-yyyy")</td>
							<td>@contract.serviceLevel</td>
							<td>
								@if (contract.status == _10433939_PROG7311_Part2.Models.ContractStatus.Draft)
								{
									<span class="badge bg-warning text-light">Draft</span>
								}
								else if (contract.status == _10433939_PROG7311_Part2.Models.ContractStatus.OnHold)
								{
									<span class="badge bg-warning text-light">OnHold</span>
								}
								else if (contract.status == _10433939_PROG7311_Part2.Models.ContractStatus.Expired)
								{
									<span class="badge bg-danger text-light">Expired</span>
								}
								else if (contract.status == _10433939_PROG7311_Part2.Models.ContractStatus.Active)
								{
									<span class="badge bg-success text-light">Active</span>
								}
								else
								{
									<span class="badge bg-success text-light">Active</span>
								}
							</td>
							<td>
								<a href="/Contracts/Details/@contract.contractId" class="btn btn-sm btn-outline-primary">View Details</a>
								<a href="/Contracts/Review/@contract.contractId" class="btn btn-sm btn-outline-primary">Change Status</a>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}

	</div>
</div>
